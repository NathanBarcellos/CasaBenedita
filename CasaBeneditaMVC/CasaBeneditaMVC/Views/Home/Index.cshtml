@{
    ViewData["Title"] = "Casa Benedita";
}


<div class="Banner">
    <a href="#Email">
        <img src="/Images/reserva-atualizado.jpg" class="img-fluid hero-image"
             alt="Imagem de destaque do restaurante">
</div></a>

<section id="about" class="about section">
    <div class="container section-title" data-aos="fade-up">
    </div>

    <div class="container">
        <div class="row gy-4">
            <div class="col-lg-7" data-aos="fade-up" data-aos-delay="100">
                <img src="/Images/COZINHA.png" class="img-fluid mb-4" alt="Interior do restaurante">
                <div class="book-a-table">
                </div>
            </div>
            <div class="col-lg-5" data-aos="fade-up" data-aos-delay="250">
                <div class="content ps-0 ps-lg-5">
                    <p class="fst-italic">
                        Na Dona Benedita, acreditamos que a comida une as pessoas. Nossa jornada começou com receitas de família
                        passadas por gerações.
                    </p>
                    <ul>
                        <li><i class="bi bi-check-circle-fill"></i> <span>Ingredientes frescos colhidos no dia.</span></li>
                        <li>
                            <i class="bi bi-check-circle-fill"></i> <span>Ambiente acolhedor e familiar para seus amigos.</span>
                        </li>
                        <li><i class="bi bi-check-circle-fill"></i> <span>Pratos feitos na hora com temperos naturais.</span></li>
                    </ul>
                    <p>
                        Trabalhamos duro para garantir que cada garfada seja uma lembrança afetiva. Do nosso fogão para a sua
                        mesa, sempre com o carinho que você merece.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="menu" class="menu section">
    <div class="container section-title" data-aos="fade-up">
    </div>

    <div class="container">
        <ul class="nav nav-tabs d-flex justify-content-center" data-aos="fade-up" data-aos-delay="100">
            <li class="nav-item">
                <a class="nav-link active show" data-bs-toggle="tab" data-bs-target="#menu-starters">
                    <h4>Entradas</h4>
                </a>
            </li>

        </ul>

        <div class="tab-content" data-aos="fade-up" data-aos-delay="200">
            <div class="tab-pane fade active show" id="menu-starters">
                <div class="tab-header text-center">
                    <p>Menu</p>
                    <h3>Entradas</h3>
                    <div class="carousel">

                        <div class="carousel">

                            <button class="prev">&#10094;</button>

                            <div class="carousel-track">

                                <div class="dish">
                                    <img src="MenuCardapio/Images/Brownie com sorvete.png" alt="">
                                    <h3>Bruschetta de Tomate</h3>
                                    <p>Pão artesanal, tomates frescos, manjericão e azeite.</p>
                                </div>

                                <div class="dish">
                                    <img src="MenuCardapio/Images/Mousse de chocolate.png" alt="">
                                    <h3>Salada Especial</h3>
                                    <p>Mix de folhas, tomate cereja e queijo.</p>
                                </div>

                                <div class="dish">
                                    <img src="/Images/entrada.png" alt="">
                                    <h3>Entrada da Casa</h3>
                                    <p>Petisco especial da cozinha.</p>
                                </div>

                            </div>

                            <button class="next">&#10095;</button>

                        </div>

</section>

<section id="book-a-table" class="book-a-table section">

    <div class="container section-title">
        <h2>Reservar Mesa</h2>
        <p><span>Garanta seu</span> <span class="description-title">Lugar Conosco</span></p>
    </div>

    <div class="container">

        <form class="Formulario" id="Email">

            <div class="row gy-4">

                <div class="col-lg-4 col-md-6">
                    <input type="text" name="name" class="form-control" id="name" placeholder="Seu Nome" required>
                </div>

                <div class="col-lg-4 col-md-6">
                    <input type="email" class="form-control" name="email" id="email" placeholder="Seu E-mail" required>
                </div>

                <div class="col-lg-4 col-md-6">
                    <input type="text" class="form-control" name="phone" id="phone" placeholder="Seu Telefone" required>
                </div>

                <div class="col-lg-4 col-md-6">
                    <input type="number" class="form-control" name="people" id="people" placeholder="Nº de pessoas" required>
                </div>

            </div>

            <div class="form-group mt-3">
                <textarea id="message" class="form-control" name="message" rows="5"
                          placeholder="Mensagem / Observação"></textarea>
            </div>

            <div class="text-center mt-3">

                <div class="loading" style="display:none;">Carregando...</div>

                <div class="sent-message" style="display:none;">
                    Seu pedido de reserva foi enviado. Ligaremos em breve para confirmar.
                </div>
                <a href="Home/Reserva" class="btn btn-success">
                    Reservar Mesa
                </a>

            </div>

        </form>
    </div>

</section>
</section>



<a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
    <i class="bi bi-arrow-up-short"></i>
</a>

<div id="preloader"></div>

<script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/vendor/aos/aos.js"></script>
<script src="/vendor/glightbox/js/glightbox.min.js"></script>
<script src="/vendor/purecounter/purecounter_vanilla.js"></script>
<script src="/vendor/swiper/swiper-bundle.min.js"></script>
<script src="/js/main.js"></script>

<script>
    const track = document.querySelector('.carousel-track')
    const slides = document.querySelectorAll('.dish')

    let index = 0

    document.querySelector('.next').onclick = () => {
      index++
      if (index >= slides.length) {
        index = 0
      }
      track.style.transform = `translateX(-${index * 100}%)`
    }

    document.querySelector('.prev').onclick = () => {
      index--
      if (index < 0) {
        index = slides.length - 1
      }
      track.style.transform = `translateX(-${index * 100}%)`
    }


    const toggle = document.querySelector('.mobile-nav-toggle');
    const navmenu = document.querySelector('#navmenu');

    toggle.addEventListener('click', () => {
      navmenu.classList.toggle('active');

      // troca ícone (hambúrguer ↔ X)
      toggle.classList.toggle('bi-list');
      toggle.classList.toggle('bi-x');
    });


</script>
<script>
    document.querySelector('Formulario').addEventListener('submit', function (event) {
      event.preventDefault(); // Impede o recarregamento da página

      // Aqui você poderia adicionar a lógica de "Carregando..."
      const loading = document.querySelector('.loading');
      const sentMessage = document.querySelector('.sent-message');

      loading.style.display = 'block';

      // Simula um tempo de envio de 1.5 segundos e depois redireciona
      setTimeout(() => {
        loading.style.display = 'none';
        sentMessage.style.display = 'block';

        // Redireciona para a página de mesas após o "sucesso"
        window.location.href = "mesas.html";
      }, 1500);
    });
</script>

<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="loginModalLabel">Acesse sua Conta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="logomodal">
                <img src="/Images/logo.webp" alt="Logo Casa Benedita" class="logo-icon">
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label for="loginEmail" class="form-label">E-mail</label>
                        <input type="email" class="form-control" id="loginEmail" placeholder="seu@email.com" required>
                    </div>
                    <div class="mb-3">
                        <label for="loginPassword" class="form-label">Senha</label>
                        <input type="password" class="form-control" id="loginPassword" required>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">Lembrar de mim</label>
                        </div>
                        <a href="#" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal" class="text-decoration-none"
                           style="color: #e06d0f;">
                            Esqueceu a senha?
                        </a>

                    </div>
                    <button type="submit" class="btn w-100"
                            style="background-color: #cf631a; color: white; border-radius: 50px; padding: 10px;">
                        ENTRAR
                    </button>
                </form>
            </div>
            <div class="modal-footer justify-content-center">
                <a href="modal fade" data-bs-toggle="modal" data-bs-target="#registerModal"
                   style="color: #d65c0a; font-weight: bold;">
                    Cadastre-se
                </a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="registerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Criar Nova Conta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Nome Completo</label>
                        <input type="text" class="form-control" placeholder="Seu nome">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">E-mail</label>
                        <input type="email" class="form-control" placeholder="seu@email.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Senha</label>
                        <input type="password" class="form-control">
                    </div>
                    <button type="submit" class="btn w-100"
                            style="background-color: #cf631a; color: white; border-radius: 50px; padding: 10px;">
                        CADASTRAR
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="forgotPasswordLabel">Recuperar Senha</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="logomodal text-center mt-3">
                <img src="/Images/logo.webp" alt="Logo Casa Benedita" class="logo-icon" style="width: 80px;">
            </div>

            <div class="modal-body p-4">
                <p class="text-muted text-center mb-4">
                    Insira seu e-mail abaixo. Enviaremos um link para você redefinir sua senha.
                </p>

                <form>
                    <div class="mb-3">
                        <label for="recoveryEmail" class="form-label">E-mail de Cadastro</label>
                        <input type="email" class="form-control" id="recoveryEmail" placeholder="seu@email.com" required>
                    </div>

                    <button type="submit" class="btn w-100"
                            style="background-color: #cf631a; color: white; border-radius: 50px; padding: 10px; font-weight: bold;">
                        ENVIAR LINK DE RECUPERAÇÃO
                    </button>
                </form>
            </div>

            <div class="modal-footer justify-content-center">
                <p>
                    Lembrou a senha?
                    <a href="#" data-bs-toggle="modal" data-bs-target="#loginModal" style="color: #d65c0a; font-weight: bold;">
                        Voltar para o Login
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>
