@model CasaBeneditaMVC.Models.Produto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Cadastrar Produto";
}

<div class="container mt-5 mb-5">

    <h2 class="mb-4">Cadastrar Produto</h2>

    <!-- ERROS -->
    <div asp-validation-summary="All" class="text-danger"></div>

    <form asp-action="Create" method="post">

        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Descrição</label>
            <input asp-for="Descricao" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Preço</label>
            <input asp-for="Preco"
                   type="number"
                   step="0.01"
                   class="form-control" />
            <span asp-validation-for="Preco" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Categoria</label>
            <select asp-for="CategoriaId" class="form-control">
                <option value="">Selecione uma categoria</option>
                <option value="1">Entradas</option>
                <option value="2">Pratos Principais</option>
                <option value="3">Bebidas</option>
                <option value="4">Sobremesas</option>
            </select>
            <span asp-validation-for="CategoriaId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">ImagemUrl</label>
            <input asp-for="ImagemUrl"
                   class="form-control"
                   placeholder="Ex: sopa.png" />
        </div>

        <button type="submit" class="btn btn-primary">
            Salvar
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Voltar
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}