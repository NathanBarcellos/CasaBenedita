@model IEnumerable<CasaBeneditaMVC.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<h1>Produtos</h1>

@if (!Model.Any())
{
    <p>Nenhum produto cadastrado no momento.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Imagem</th>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Preço</th>
                <th>Disponível</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var produto in Model)
            {
                <tr>
                    <td>
                        <img src="/Images/@produto.ImagemUrl"
                             style="width:80px; height:80px; object-fit:cover;" />
                    </td>
                    <td>@produto.Nome</td>
                    <td>@produto.Descricao</td>
                    <td>R$ @produto.Preco.ToString("N2")</td>
                    <td>@(produto.Disponivel ? "Sim" : "Não")</td>
                </tr>
            }
        </tbody>
    </table>
}