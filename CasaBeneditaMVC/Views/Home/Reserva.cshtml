@{
    ViewData["Title"] = "Reserva de Mesas";
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reserva de Mesas - Casa Benedita</title>

    <link rel="stylesheet" href="/assets/css/style.css">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>

<body>

    <header>
        <nav class="navbar">
            <div class="logo">CASA BENEDITA</div>
        </nav>
    </header>

    <form method="post" asp-controller="Reserva" asp-action="Criar">

        <main class="container">

            <!-- 🔥 MENSAGENS -->
            @if (TempData["Sucesso"] != null)
            {
                <div style="background-color:#28a745; color:white; padding:12px; margin-bottom:15px; border-radius:6px; font-weight:bold;">
                    @TempData["Sucesso"]
                </div>
            }

            @if (TempData["Erro"] != null)
            {
                <div style="background-color:#dc3545; color:white; padding:12px; margin-bottom:15px; border-radius:6px; font-weight:bold;">
                    @TempData["Erro"]
                </div>
            }

            <h1>Selecione sua Mesa</h1>
            <p>Escolha um horário e sua mesa.</p>

            <!-- 🔵 DADOS DO CLIENTE -->
            <div style="margin-bottom:15px;">
                <input type="text" name="NomeCliente" placeholder="Seu nome" required class="form-control" />
            </div>

            <div style="margin-bottom:15px;">
                <input type="email" name="EmailCliente" placeholder="Seu email" required class="form-control" />
            </div>

            <div style="margin-bottom:15px;">
                <input type="text" name="TelefoneCliente" placeholder="Seu telefone" required class="form-control" />
            </div>

            <!-- 🔵 HORÁRIO -->
            <div class="horario">
                <label><strong>Horário:</strong></label>
                <input type="time" id="horario">
            </div>

            <!-- 🔵 MESAS -->
            <div class="mesa-grid">

                @for (int i = 1; i <= 6; i++)
                {
                    <div class="mesa" onclick="selecionarMesa(this)">
                        <div class="cadeira cadeira-top"></div>
                        <div class="cadeira cadeira-left"></div>

                        <div class="tampo">@i.ToString("00")</div>

                        <div class="cadeira cadeira-right"></div>
                        <div class="cadeira cadeira-bottom"></div>
                    </div>
                }

            </div>

            <div class="legenda">
                <span><span class="cor disp"></span>Disponível</span>
                <span><span class="cor sel"></span>Selecionada</span>
            </div>

            <!-- CAMPOS OCULTOS -->
            <input type="hidden" name="MesaId" id="mesaId" />
            <input type="hidden" name="HorarioReserva" id="horarioReserva" />

            <button type="submit" class="btn-reservar" onclick="prepararReserva(event)">
                Confirmar Reserva
            </button>

        </main>

    </form>

    <script>

        function selecionarMesa(mesa){
            document.querySelectorAll('.mesa')
                .forEach(m => m.classList.remove('selecionada'));

            mesa.classList.add('selecionada');
        }

        function prepararReserva(event){

            const horario = document.getElementById("horario").value;
            const mesa = document.querySelector(".mesa.selecionada");

            if(!horario){
                alert("Escolha um horário");
                event.preventDefault();
                return;
            }

            if(!mesa){
                alert("Selecione uma mesa");
                event.preventDefault();
                return;
            }

            const numeroMesa = mesa.querySelector(".tampo").innerText;

            document.getElementById("mesaId").value = numeroMesa;
            document.getElementById("horarioReserva").value = horario;
        }

    </script>

</body>
</html>