<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <title>Casa Benedita</title>

    <meta name="description" content="Restaurante Dona Benedita - Comida caseira e saudável.">
    <meta name="keywords" content="restaurante, comida caseira, dona benedita">

    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Amatic+SC:wght@400;700&display=swap"
          rel="stylesheet">

    <link href="~/css/site.css" rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body class="index-page">

    <header id="header"
            class="header-overlay d-flex align-items-center">

        <div class="container d-flex align-items-center justify-content-between">

            <!-- LOGO -->
            <a asp-controller="Home"
               asp-action="Index"
               class="logo d-flex align-items-center">

                <img src="~/Images/logo.png"
                     alt="Logo"
                     class="logo-icon">

                <h1 class="logo-text">
                    CASA BENEDITA
                </h1>

            </a>

            <!-- MENU -->
            <nav id="navmenu"
                 class="navmenu">

                <ul>

                    <li>
                        <a asp-controller="Home"
                           asp-action="Index">

                            INÍCIO

                        </a>
                    </li>

                    <li>
                        <a asp-controller="Cardapio"
                           asp-action="Index">

                            CARDÁPIO

                        </a>
                    </li>

                    <li>
                        <a asp-controller="Reserva"
                           asp-action="Index">

                            RESERVAS

                        </a>
                    </li>

                    <!-- BOTÃO LOGIN / LOGOUT -->
                    <li>

                        @using Microsoft.AspNetCore.Http

                        @if (Context.Session.GetString("UsuarioLogado") == null)
                        {
                            <a href="#"
                               class="btn-entrar"
                               data-bs-toggle="modal"
                               data-bs-target="#loginModal">

                                ENTRAR

                            </a>
                        }
                        else
                        {
                            <a asp-controller="Usuario"
                               asp-action="Logout"
                               class="btn-entrar">

                                SAIR

                            </a>
                        }

                    </li>

                </ul>

            </nav>

            <!-- MENU HAMBURGUER -->
            <div class="menu-hamburguer"
                 id="btnMenu">

                <i class="fa-solid fa-bars"></i>

            </div>

        </div>

    </header>

    <!-- HERO -->
    <main>

        <section class="hero-full">

            <img src="~/Images/Fachada.png"
                 alt="Banner"
                 class="hero-bg">

            <div class="hero-container">

                <div class="hero-content"
                     data-aos="fade-up">

                    <h2>Faça sua Reserva</h2>

                    <p>
                        Garanta seu lugar com mais conforto.
                    </p>

                    <a asp-controller="Reserva"
                       asp-action="Index"
                       class="btn-book">

                        RESERVE AGORA SUA MESA

                    </a>

                </div>

            </div>

        </section>

        <!-- SOBRE -->
        <section id="about"
                 class="about section">

            <div class="container">

                <div class="row gy-4">

                    <div class="col-lg-7"
                         data-aos="fade-up"
                         data-aos-delay="100">

                        <img src="~/Images/COZINHA.png"
                             class="img-fluid mb-4"
                             alt="Interior do restaurante">

                    </div>

                    <div class="col-lg-5"
                         data-aos="fade-up"
                         data-aos-delay="250">

                        <div class="content ps-0 ps-lg-5">

                            <h2>Sobre Nós</h2>

                            <p class="fst-italic">

                                Na Dona Benedita, acreditamos que a comida une as pessoas.

                            </p>

                            <ul>

                                <li>
                                    🔥 Ingredientes frescos
                                </li>

                                <li>
                                    🍷 Ambiente acolhedor
                                </li>

                                <li>
                                    🥩 Pratos preparados na hora
                                </li>

                            </ul>

                        </div>

                    </div>

                </div>

            </div>

        </section>

    </main>

    <!-- FOOTER -->
    <footer class="footer-pro">

        <div class="footer-container">

            <div class="footer-col">

                <p>
                    <strong>Localização:</strong><br>

                    Rua Barão de Capanema, 2900<br>

                    Jardins - São Paulo | SP
                </p>

                <p>
                    <strong>Reservas:</strong><br>

                    21 2493-2021
                </p>

            </div>

            <div class="footer-col">

                <h3>Funcionamento</h3>

                <ul>

                    <li>
                        Segunda à Sexta — 18h às 00h
                    </li>

                    <li>
                        Sábado — 19h às 00h
                    </li>

                    <li>
                        Domingo — 18h às 22h
                    </li>

                </ul>

            </div>

        </div>

    </footer>

    <!-- JS -->
    <script>

        const btnMenu =
            document.getElementById("btnMenu");

        const navMenu =
            document.getElementById("navmenu");

        btnMenu.addEventListener("click", () => {

            navMenu.classList.toggle("active");

        });

    </script>

</body>

</html>