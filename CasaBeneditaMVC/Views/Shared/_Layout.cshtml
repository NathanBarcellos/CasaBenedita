<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Casa Benedita</title>

    <meta name="description" content="Restaurante Casa Benedita" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Roboto:wght@300;400;500;700&family=Inter&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    @RenderSection("Styles", required: false)
</head>

<body>

    @RenderBody()

    <!-- LOGIN MODAL -->
    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Acesse sua Conta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="text-center mt-3">
                    <img src="~/Images/logo.webp" style="width:80px;">
                </div>

                <div class="modal-body p-4">

                    @if (TempData["ErroLogin"] != null)
                    {
                        <div class="alert alert-danger text-center">
                            @TempData["ErroLogin"]
                        </div>
                    }

                    <form asp-controller="Usuario" asp-action="Login" method="post">

                        <div class="mb-3">
                            <label>E-mail</label>
                            <input name="email" type="email" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label>Senha</label>
                            <input name="senha" type="password" class="form-control" required>
                        </div>

                        <button class="btn w-100"
                                style="background:#cf631a; color:white; border-radius:50px;">
                            ENTRAR
                        </button>

                    </form>
                </div>

                <div class="modal-footer justify-content-center">
                    <a href="#" data-bs-toggle="modal" data-bs-target="#registerModal"
                       style="color:#cf631a; font-weight:bold;">
                        Cadastre-se
                    </a>
                </div>

            </div>
        </div>
    </div>

    <!-- REGISTER MODAL -->
    <div class="modal fade" id="registerModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title fw-bold">Criar conta</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="text-center mt-3">
                    <img src="~/Images/logo.webp" style="width:80px;">
                </div>

                <div class="modal-body p-4">
                    <form asp-controller="Usuario" asp-action="Cadastrar" method="post">

                        <div class="mb-3">
                            <label>Nome</label>
                            <input name="Nome" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input name="Email" type="email" class="form-control" required>
                        </div>

                        <div class="mb-3">
                            <label>Senha</label>
                            <input name="Senha" type="password" class="form-control" required>
                        </div>

                        <button class="btn w-100"
                                style="background:#cf631a; color:white; border-radius:50px;">
                            CADASTRAR
                        </button>

                    </form>
                </div>

                <div class="modal-footer justify-content-center">
                    <a href="#" data-bs-toggle="modal" data-bs-target="#loginModal"
                       style="color:#cf631a; font-weight:bold;">
                        Já tenho conta
                    </a>
                </div>

            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

    @if (TempData["ErroLogin"] != null)
    {
        <script>
            var modal = new bootstrap.Modal(document.getElementById('loginModal'));
            modal.show();
        </script>
    }

</body>
</html>