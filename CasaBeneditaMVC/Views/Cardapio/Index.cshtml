@model List<CasaBeneditaMVC.Models.Produto>

<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cardápio - Casa Benedita</title>

    <link rel="stylesheet" href="~/css/cardapio.css">

    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Amatic+SC:wght@400;700&display=swap" rel="stylesheet">

</head>

<body>

    <header class="menu-header">
        <div class="container">

            <a asp-controller="Home"
               asp-action="Index"
               class="back-btn">
                <i class="fas fa-arrow-left"></i> Voltar
            </a>

            <div class="logo">
                <img src="/Images/logo.png" width="80" alt="Logo">
                <h1>CASA BENEDITA</h1>
            </div>

        </div>
    </header>

    <!-- PESQUISA -->
    <div style="padding:20px; text-align:center;">

        <form method="get"
              asp-controller="Cardapio"
              asp-action="Index">

            <input type="text"
                   name="pesquisa"
                   placeholder="Pesquisar pratos..."
                   style="
                        width:300px;
                        padding:12px;
                        border-radius:30px;
                        border:1px solid #ccc;
                        outline:none;
                        font-size:16px;">

            <button type="submit"
                    style="
                        background:#cf631a;
                        color:white;
                        border:none;
                        padding:12px 25px;
                        border-radius:30px;
                        margin-left:10px;
                        font-weight:bold;">
                Pesquisar
            </button>

        </form>
    </div>

    <!-- PRATOS PRINCIPAIS -->
    <section class="menu-section">
        <div class="container">

            <h2>🥩 PRATOS PRINCIPAIS</h2>

            <div class="dishes-grid">

                @if (Model.Where(p => p.CategoriaId == 2).Any())
                {
                    @foreach (var produto in Model.Where(p => p.CategoriaId == 2))
                    {
                        <div class="dish-card">

                            <div class="dish-image"
                                 style="background-image: url('/Images/@produto.ImagemUrl');">
                            </div>

                            <div class="dish-info">

                                <h3>@produto.Nome</h3>

                                <div class="preco-botao">

                                    <span class="price">
                                        R$ @produto.Preco.ToString("F2")
                                    </span>

                                    <div class="botao"
                                         onclick="addToCart(@produto.ProdutoId, '@produto.Nome', @produto.Preco)">
                                        Comprar
                                    </div>

                                </div>

                            </div>

                        </div>
                    }
                }
                else
                {
                    <div style="
                                    width:100%;
                                    text-align:center;
                                    padding:40px;
                                    font-size:24px;
                                    color:#cf631a;
                                    font-weight:bold;">

                        Nenhum prato encontrado 😢

                    </div>
                }

            </div>
        </div>
    </section>

    <!-- ENTRADAS -->
    <section class="menu-section">
        <div class="container">

            <h2>🍽️ ENTRADAS</h2>

            <div class="dishes-grid">

                @foreach (var produto in Model.Where(p => p.CategoriaId == 1))
                {
                    <div class="dish-card">

                        <div class="dish-image"
                             style="background-image: url('/Images/@produto.ImagemUrl');">
                        </div>

                        <div class="dish-info">

                            <h3>@produto.Nome</h3>

                            <div class="preco-botao">

                                <span class="price">
                                    R$ @produto.Preco.ToString("F2")
                                </span>

                                <div class="botao"
                                     onclick="addToCart(@produto.ProdutoId, '@produto.Nome', @produto.Preco)">
                                    Comprar
                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>
    </section>

    <!-- SOBREMESAS -->
    <section class="menu-section">
        <div class="container">

            <h2>🍰 SOBREMESAS</h2>

            <div class="dishes-grid">

                @foreach (var produto in Model.Where(p => p.CategoriaId == 4))
                {
                    <div class="dish-card">

                        <div class="dish-image"
                             style="background-image: url('/Images/@produto.ImagemUrl');">
                        </div>

                        <div class="dish-info">

                            <h3>@produto.Nome</h3>

                            <div class="preco-botao">

                                <span class="price">
                                    R$ @produto.Preco.ToString("F2")
                                </span>

                                <div class="botao"
                                     onclick="addToCart(@produto.ProdutoId, '@produto.Nome', @produto.Preco)">
                                    Comprar
                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>
    </section>

    <!-- BEBIDAS -->
    <section class="menu-section">
        <div class="container">

            <h2>🍹 BEBIDAS</h2>

            <div class="dishes-grid">

                @foreach (var produto in Model.Where(p => p.CategoriaId == 3))
                {
                    <div class="dish-card">

                        <div class="dish-image"
                             style="background-image: url('/Images/@produto.ImagemUrl');">
                        </div>

                        <div class="dish-info">

                            <h3>@produto.Nome</h3>

                            <div class="preco-botao">

                                <span class="price">
                                    R$ @produto.Preco.ToString("F2")
                                </span>

                                <div class="botao"
                                     onclick="addToCart(@produto.ProdutoId, '@produto.Nome', @produto.Preco)">
                                    Comprar
                                </div>

                            </div>

                        </div>

                    </div>
                }

            </div>
        </div>
    </section>

    <!-- CARRINHO -->
    <div id="cart-button" onclick="toggleCart()">
        <i class="fas fa-shopping-cart"></i>
        <span id="cart-count">0</span>
    </div>

    <div id="cart" class="cart">

        <div style="display:flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ddd; padding-bottom: 10px;">

            <h2 style="margin:0;">🛒 Seu Pedido</h2>

            <button onclick="toggleCart()"
                    style="background:none; border:none; font-size: 24px; cursor:pointer; color:#8B4513;">
                &times;
            </button>

        </div>

        <div id="cart-items">
            <p style="text-align:center; padding:20px; color:#666;">
                Seu carrinho está vazio 🛍️
            </p>
        </div>

        <div style="border-top: 2px solid #eee; padding-top: 15px;">

            <div style="display:flex;justify-content:space-between; margin-bottom: 5px;">
                <span>Subtotal</span>
                <span id="subtotal">R$ 0,00</span>
            </div>

            <div style="display:flex;justify-content:space-between;font-weight:bold; font-size: 1.2rem; margin-top:10px; color:#27ae60;">
                <span>Total</span>
                <span id="total">R$ 0,00</span>
            </div>

            <button onclick="irParaCheckout()"
                    style="margin-top:20px;width:100%;padding:15px;background:#27ae60;color:white;border:none;border-radius:8px; font-weight:bold; cursor:pointer; font-size:1rem;">

                Finalizar Pedido

            </button>

        </div>
    </div>

    <script>

        let cart = [];

        function addToCart(produtoId, nome, preco) {

            const item = cart.find(i => i.produtoId === produtoId);

            if (item) {

                item.quantidade++;

            } else {

                cart.push({
                    produtoId: produtoId,
                    nome: nome,
                    preco: preco,
                    quantidade: 1
                });
            }

            updateCart();

            document.getElementById("cart")
                .classList.add("active");
        }

        function updateCart() {

            const container = document.getElementById("cart-items");
            const subtotalEl = document.getElementById("subtotal");
            const totalEl = document.getElementById("total");
            const countEl = document.getElementById("cart-count");

            container.innerHTML = "";

            let subtotal = 0;
            let count = 0;

            if (cart.length === 0) {

                container.innerHTML =
                    "<p style='text-align:center; padding:20px; color:#666;'>Seu carrinho está vazio 🛍️</p>";

                subtotalEl.textContent = "R$ 0,00";
                totalEl.textContent = "R$ 0,00";
                countEl.textContent = "0";

                return;
            }

            cart.forEach((item, index) => {

                subtotal += item.preco * item.quantidade;
                count += item.quantidade;

                const div = document.createElement("div");

                div.style.display = "flex";
                div.style.justifyContent = "space-between";
                div.style.alignItems = "center";
                div.style.padding = "10px 0";
                div.style.borderBottom = "1px solid #eee";

                div.innerHTML = `
                    <div style="flex:1">
                        <strong style="font-size:0.9rem">${item.nome}</strong><br>
                        <small>R$ ${item.preco.toFixed(2)}</small>
                    </div>

                    <div style="display:flex; align-items:center; gap:8px">
                        <button onclick="changeQty(${index}, -1)" style="width:25px; cursor:pointer">-</button>
                        <span>${item.quantidade}</span>
                        <button onclick="changeQty(${index}, 1)" style="width:25px; cursor:pointer">+</button>
                    </div>

                    <button onclick="removeItem(${index})"
                            style="background:none; border:none; color:red; margin-left:10px; cursor:pointer">
                        <i class="fas fa-trash"></i>
                    </button>
                `;

                container.appendChild(div);
            });

            let total = subtotal;

            subtotalEl.textContent = `R$ ${subtotal.toFixed(2).replace('.', ',')}`;
            totalEl.textContent = `R$ ${total.toFixed(2).replace('.', ',')}`;
            countEl.textContent = count;
        }

        function changeQty(index, delta) {

            cart[index].quantidade += delta;

            if (cart[index].quantidade <= 0) {
                cart.splice(index, 1);
            }

            updateCart();
        }

        function removeItem(index) {

            cart.splice(index, 1);

            updateCart();
        }

        function toggleCart() {

            document.getElementById("cart")
                .classList.toggle("active");
        }

        function irParaCheckout() {

            localStorage.setItem("carrinho", JSON.stringify(cart));

            window.location.href = "/Pedido/Checkout";
        }

    </script>

</body>
</html>