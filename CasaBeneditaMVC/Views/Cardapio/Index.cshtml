@{
    ViewData["Title"] = "Cardápio";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cardapio.css" />
}

<header class="menu-header">
    <div class="container">
        <a asp-controller="Home" asp-action="Index" class="back-btn">
            ← Voltar
        </a>

        <div class="logo">
            <img src="~/Images/logo.webp" width="80" />
            <h1>Casa Benedita</h1>
        </div>
    </div>
</header>

<!-- PRATOS -->
<section class="menu-section">
    <div class="container">
        <h2>🥩 PRATOS PRINCIPAIS</h2>

        <div class="dishes-grid">

            <div class="dish-card">
                <img src="~/Images/Pratos/picanha.png" />
                <div class="dish-info">
                    <h3>Picanha da Dona Benedita</h3>
                    <div class="preco-botao">
                        <span class="price">R$ 64,90</span>
                        <div class="botao">Comprar</div>
                    </div>
                </div>
            </div>

            <div class="dish-card">
                <img src="~/Images/Pratos/Costela.png" />
                <div class="dish-info">
                    <h3>Costela ao Molho Barbecue</h3>
                    <div class="preco-botao">
                        <span class="price">R$ 61,90</span>
                        <div class="botao">Comprar</div>
                    </div>
                </div>
            </div>

            <div class="dish-card">
                <img src="~/Images/Pratos/FileMignon.png" />
