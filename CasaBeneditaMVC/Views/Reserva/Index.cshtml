<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reserva - CASA BENEDITA</title>
    <link rel="stylesheet" href="../wwwroot/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

    <div class="container">
        <div class="card">
            <header>
                <div class="lang-selector">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/0/05/Flag_of_Brazil.svg" alt="Brasil">
                    <span>PT</span>
                </div>
                <h1>CASA BENEDITA</h1>
                <p class="subtitle">Faça sua reserva!</p>
            </header>

            <form id="reservaForm">
                <div class="input-group top-section">
                    <div class="label-row">
                        <label>Onde?</label>
                        <span id="txt-local" class="placeholder">Selecione...</span>
                        <i class="fa-solid fa-location-dot icon-gold"></i>
                    </div>

                    <select id="estado" class="custom-select">
                        <option value="" disabled selected>Estado*</option>
                        <option value="SP">São Paulo</option>
                        <option value="PR">Paraná</option>
                        <option value="SC">Santa Catarina</option>
                    </select>

                    <select id="cidade" class="custom-select">
                        <option value="" disabled selected>Cidade*</option>
                        <option value="curitiba">Curitiba</option>
                        <option value="sao-paulo">São Paulo</option>
                        <option value="joinville">Joinville</option>
                    </select>
                </div>

                <div class="next-row">
                    <button type="button" id="btn-proximo" class="btn-text">Próximo</button>
                </div>

                <hr class="divider">

                <div class="input-row disabled" data-tipo="unidade">
                    <span>Qual unidade?</span>
                    <span class="selection" id="res-unidade">Selecione...</span>
                    <i class="fa-solid fa-store"></i>
                </div>

                <div class="input-row disabled" data-tipo="pessoas">
                    <span>Quantas pessoas?</span>
                    <span class="selection" id="res-pessoas">0</span>
                    <i class="fa-solid fa-users"></i>
                </div>

                <div class="input-row disabled" data-tipo="horario">
                    <span>Qual horário?</span>
                    <span class="selection" id="res-horario">Selecione...</span>
                    <i class="fa-regular fa-clock"></i>
                </div>

                <footer>
                    <button type="submit" id="btn-continuar" class="btn-continue" disabled>Continuar</button>
                </footer>
            </form>
        </div>
    </div>

    <div id="modal-selecao" class="modal">
        <div class="modal-content">
            <h3 id="modal-titulo">Escolha uma opção</h3>
            <ul id="lista-opcoes">
            </ul>
            <button class="btn-fechar" onclick="fecharModal()">Fechar</button>
        </div>
    </div>

    <script src="RESERVAjs.js"></script>
</body>

<style>
    /* Reset básico */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
        background-color: #f4f4f4; /* Fundo mais claro para contraste */
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 20px;
    }

    .container {
        width: 100%;
        max-width: 450px;
    }

    .card {
        background-color: #fff;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        position: relative;
    }

    /* Header */
    header {
        text-align: center;
        margin-bottom: 30px;
    }

    .lang-selector {
        position: absolute;
        top: 20px;
        right: 20px;
        border: 1px solid #eee;
        border-radius: 20px;
        padding: 4px 10px;
        display: flex;
        align-items: center;
        background: #fff;
        font-size: 12px;
        color: #777;
    }

        .lang-selector img {
            width: 18px;
            margin-right: 5px;
        }

    h1 {
        font-size: 32px;
        letter-spacing: 3px;
        font-weight: 600;
        color: #000;
    }

    .subtitle {
        color: #c5a059; /* Dourado Madero */
        font-weight: bold;
        font-size: 13px;
        text-transform: uppercase;
    }

    /* Inputs e Selects */
    .custom-select {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 5px;
        color: #333;
        margin-bottom: 15px;
        background-color: #fff;
        font-size: 14px;
    }

    .next-row {
        text-align: right;
        margin-bottom: 10px;
    }

    .btn-text {
        background: none;
        border: none;
        color: #c5a059;
        font-weight: bold;
        cursor: pointer;
        font-size: 14px;
    }

    .divider {
        border: 0;
        border-top: 1px solid #eee;
        margin: 15px 0;
    }

    /* Linhas Interativas (Onde a mágica acontece) */
    .input-row {
        display: flex;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid #f9f9f9;
        font-size: 14px;
        color: #333; /* Texto agora é visível por padrão */
        cursor: pointer;
        transition: all 0.2s ease;
    }

        /* Estado Desabilitado (antes de clicar em próximo) */
        .input-row.disabled {
            color: #ccc;
            cursor: not-allowed;
            opacity: 0.6;
        }

        .input-row .selection {
            margin-left: auto;
            margin-right: 15px;
            font-weight: 500;
            color: #666;
        }

        .input-row i {
            color: #c5a059;
            font-size: 18px;
            width: 25px;
            text-align: center;
        }

    /* Botão de Finalização */
    footer {
        margin-top: 30px;
        text-align: center;
    }

    .btn-continue {
        background-color: #e0e0e0;
        color: #999;
        border: none;
        padding: 12px 60px;
        border-radius: 25px;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 13px;
        cursor: not-allowed;
        transition: 0.3s;
    }

        /* Quando o formulário estiver pronto para enviar */
        .btn-continue.active {
            background-color: #c5a059;
            color: #fff;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(197, 160, 89, 0.3);
        }

    /* Estilo do Modal de Opções */
    .modal {
        display: none; /* Escondido por padrão */
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.4);
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-content {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
        width: 85%;
        max-width: 350px;
    }

        .modal-content h3 {
            margin-bottom: 15px;
            font-size: 16px;
            color: #333;
            text-align: center;
        }

        .modal-content ul {
            list-style: none;
        }

        .modal-content li {
            padding: 12px;
            border-bottom: 1px solid #eee;
            cursor: pointer;
            text-align: center;
        }

            .modal-content li:hover {
                background-color: #fdfaf3;
                color: #c5a059;
            }
</style>
</html>