@{
    ViewData["Title"] = "Pagamento";
}

<link rel="stylesheet" href="~/css/checkout.css">

<div class="checkout-container" id="checkout-box">

    <h2>Finalizar Pagamento</h2>

    <!-- ENDEREÇO -->
    <div style="margin-bottom:25px;">

        <h3 style="margin-bottom:15px;">
            📍 Endereço de Entrega
        </h3>

        <div class="form-group">
            <label>Rua</label>

            <input type="text"
                   id="rua"
                   placeholder="Digite sua rua">
        </div>

        <div class="form-row">

            <div class="form-group">

                <label>Número</label>

                <input type="text"
                       id="numero"
                       placeholder="Número">

            </div>

            <div class="form-group">

                <label>CEP</label>

                <input type="text"
                       id="cep"
                       placeholder="CEP">

            </div>

        </div>

        <div class="form-group">
            <label>Bairro</label>

            <input type="text"
                   id="bairro"
                   placeholder="Bairro">
        </div>

        <div class="form-group">
            <label>Cidade</label>

            <input type="text"
                   id="cidade"
                   placeholder="Cidade">
        </div>

        <div class="form-group">
            <label>Complemento</label>

            <input type="text"
                   id="complemento"
                   placeholder="Apartamento, bloco, etc">
        </div>

    </div>

    <!-- MÉTODOS -->
    <div class="payment-methods">

        <button class="method-btn active"
                onclick="switchTab('pix')">

            PIX

        </button>

        <button class="method-btn"
                onclick="switchTab('card')">

            Cartão de Crédito

        </button>

    </div>

    <!-- PIX -->
    <div id="content-pix"
         class="tab-content active">

        <div class="qr-placeholder">

            <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=ExemploPix">

            <p>Escaneie o código para pagar</p>

        </div>

        <div class="copy-paste">

            <input type="text"
                   value="00020101021226850014br.gov.bcb.pix..."
                   readonly>

            <button type="button"
                    onclick="alert('Chave copiada!')">

                Copiar

            </button>

        </div>

        <form method="post"
              action="/Pedido/FinalizarPedido">

            <input type="hidden"
                   id="carrinhoPix"
                   name="carrinhoJson">

            <input type="hidden"
                   id="ruaPix"
                   name="rua">

            <input type="hidden"
                   id="numeroPix"
                   name="numero">

            <input type="hidden"
                   id="bairroPix"
                   name="bairro">

            <input type="hidden"
                   id="cidadePix"
                   name="cidade">

            <input type="hidden"
                   id="cepPix"
                   name="cep">

            <input type="hidden"
                   id="complementoPix"
                   name="complemento">

            <button type="submit"
                    class="confirm-btn success">

                Já realizei o pagamento

            </button>

        </form>

    </div>

    <!-- CARTÃO -->
    <div id="content-card"
         class="tab-content">

        <div class="form-group">

            <label>Número do Cartão</label>

            <input type="text"
                   placeholder="0000 0000 0000 0000">

        </div>

        <div class="form-row">

            <div class="form-group">

                <label>Validade</label>

                <input type="text"
                       placeholder="MM/AA">

            </div>

            <div class="form-group">

                <label>CVV</label>

                <input type="text"
                       placeholder="123">

            </div>

        </div>

        <div class="form-group">

            <label>Nome no Cartão</label>

            <input type="text"
                   placeholder="Como escrito no cartão">

        </div>

        <form method="post"
              action="/Pedido/FinalizarPedido">

            <input type="hidden"
                   id="carrinhoCard"
                   name="carrinhoJson">

            <input type="hidden"
                   id="ruaCard"
                   name="rua">

            <input type="hidden"
                   id="numeroCard"
                   name="numero">

            <input type="hidden"
                   id="bairroCard"
                   name="bairro">

            <input type="hidden"
                   id="cidadeCard"
                   name="cidade">

            <input type="hidden"
                   id="cepCard"
                   name="cep">

            <input type="hidden"
                   id="complementoCard"
                   name="complemento">

            <button type="submit"
                    class="confirm-btn">

                Pagar Agora

            </button>

        </form>

    </div>
</div>

<script>

    function switchTab(tab) {

        document.querySelectorAll('.tab-content')
            .forEach(el => el.classList.remove('active'));

        document.querySelectorAll('.method-btn')
            .forEach(el => el.classList.remove('active'));

        document.getElementById('content-' + tab)
            .classList.add('active');

        if (tab === 'pix') {

            document.querySelectorAll('.method-btn')[0]
                .classList.add('active');

        } else {

            document.querySelectorAll('.method-btn')[1]
                .classList.add('active');
        }
    }

    // PEGA O CARRINHO
    const carrinho = localStorage.getItem("carrinho");

    document.getElementById("carrinhoPix").value = carrinho;
    document.getElementById("carrinhoCard").value = carrinho;

    // ENVIA ENDEREÇO
    function preencherEndereco() {

        const rua = document.getElementById("rua").value;
        const numero = document.getElementById("numero").value;
        const bairro = document.getElementById("bairro").value;
        const cidade = document.getElementById("cidade").value;
        const cep = document.getElementById("cep").value;
        const complemento = document.getElementById("complemento").value;

        document.getElementById("ruaPix").value = rua;
        document.getElementById("numeroPix").value = numero;
        document.getElementById("bairroPix").value = bairro;
        document.getElementById("cidadePix").value = cidade;
        document.getElementById("cepPix").value = cep;
        document.getElementById("complementoPix").value = complemento;

        document.getElementById("ruaCard").value = rua;
        document.getElementById("numeroCard").value = numero;
        document.getElementById("bairroCard").value = bairro;
        document.getElementById("cidadeCard").value = cidade;
        document.getElementById("cepCard").value = cep;
        document.getElementById("complementoCard").value = complemento;
    }

    document.querySelectorAll("form").forEach(form => {

        form.addEventListener("submit", function () {

            preencherEndereco();
        });
    });

</script>